{
  "name": "glory-simon-interiors-lead-portal",
  "version": "1.0.0",
  "description": "Glory Simon Interiors Restaurant/Hotel Interior Lead Portal",
  "main": "index.js",
  "scripts": {
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "start": "concurrently \"npm start --prefix backend\" \"npm start --prefix frontend\"",
    "seed": "npm run seed --prefix backend",
    "test:api": "npm run test:api --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
